SERVER_PORT=4178
SESSION_SECRET=change-this-session-secret

# Admin account. Change before exposing on an intranet server.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Manufacturing Plant 1 knowledge assistant.
# Example: https://pan.wst.com:443
QA_API_BASE_URL=
QA_BOT_ID=7172f29d-69c1-4f71-9646-03ab127e8f53
QA_AUTH_CLIENT_ID=
QA_AUTH_CLIENT_SECRET=
# Optional fallback for local tests when the page is not opened from OA with ?code=...
QA_DEFAULT_ACCOUNT=

# Translation assistant model in the intranet.
TRANSLATION_API_URL=http://172.28.200.53:8088/Others/qwen3vl/v1/chat/completions
TRANSLATION_MODEL=qwen3-VL-32B

# Set to true for local UI testing when intranet APIs are unreachable.
MOCK_AI=false
